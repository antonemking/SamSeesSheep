# Animal data (DO NOT commit raw photos of livestock without explicit permission)
data/raw/
data/photos/
data/video/
*.jpg
*.jpeg
*.png
*.mp4
*.mov
*.heic
!docs/**/*.png
!docs/**/*.jpg
# Keep all data and docs local
data/
docs/

# Annotations (commit only the schema, not the labels themselves until reviewed)
data/annotations/
*.coco.json
*.label.json

# Local secrets and configs
.env
.env.local
*.local

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~

# Logs and reports (keep schemas, not contents)
logs/
*.log
reports/runs/

# Runtime data
data/uploads/
data/results/

# DVC (if added later)
/.dvc/cache
/.dvc/tmp
