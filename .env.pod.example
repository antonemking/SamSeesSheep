# Copy to `.env.pod` (gitignored) and fill in the values from Vast.ai.
# The scripts/ shell helpers read these so you don't re-type instance
# details every session.
#
# Get values from: Vast.ai console → your instance → the "IP Port Info"
# button on the instance card. Vast maps each internal port to a dynamic
# external port on the host's public IP.

# SSH: Vast shows this as `ssh -p <PORT> root@<HOST>` in the Connect dialog,
# or as the external port that maps to internal port 22 in IP Port Info.
POD_IP=66.55.44.33
POD_SSH_PORT=41922

# HTTP URL for the labeling UI (internal port 8000).
# Vast has NO proxy domain — you reach the service directly at
# http://<public-ip>:<external-port>, where <external-port> is whatever Vast
# mapped internal 8000 to (see IP Port Info). NOTE: you must request port 8000
# when you create the instance — add `-p 8000:8000` in the template's "Docker
# create/run options" box, otherwise it won't be exposed. Plain http:// with
# no proxy means the old ~60-100 s RunPod proxy timeout on SAM 3 propagation
# is gone. Still quoted for parsing safety under `set -a; . .env.pod`.
POD_HTTP_URL="http://66.55.44.33:18000"

# Path to the private key whose public key you registered in Vast.ai
# (Account → Keys → SSH Keys).
SSH_KEY=/home/toneking/.ssh/id_ed25519

# Durable labels dir — Vast Volume mount path on the instance.
# Create a Vast Volume (Console → Volumes), attach it when you rent the
# instance, and set its mount path here. A Vast Volume survives instance
# DESTROY, BUT it is tied to ONE physical machine — if you later rent a GPU on
# a different host the volume (and your labels) won't attach there. So the
# laptop mirror from scripts/backup_dataset.sh is the REAL durability layer:
# back up before you destroy an instance. Default: /workspace/labels.
LABELS_VOLUME=/workspace/labels
