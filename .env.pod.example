# Copy to `.env.pod` (gitignored) and fill in the values from RunPod.
# The scripts/ shell helpers read these so you don't re-type pod details
# every session.
#
# Get values from: RunPod console → your pod → Connect

# From "SSH over exposed TCP" section
POD_IP=203.0.113.1
POD_SSH_PORT=2222

# From "HTTP Services" section (the URL for port 8000).
# Quoted because the <pod-id> placeholder contains shell-redirect characters —
# leaving it unquoted breaks `set -a; . .env.pod` with "No such file or directory".
POD_HTTP_URL="https://POD_ID-8000.proxy.runpod.net"

# Path to the private key RunPod's settings has the matching public key for
SSH_KEY=~/.ssh/id_ed25519

# Durable labels dir — Network Volume mount path on the pod.
# Set in the RunPod UI when deploying/editing the pod ("Attach Network Volume"
# → mount path). start_pod_server.sh symlinks data/labels → this path so
# labels survive Terminate / spot preemption. Default: /mnt/labels.
LABELS_VOLUME=/mnt/labels
